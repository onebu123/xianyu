{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node --max-old-space-size=4096 ../node_modules/typescript/bin/tsc -p tsconfig.json",
    "preflight": "tsx src/preflight-cli.ts",
    "db:inspect": "tsx src/db-inspect-cli.ts",
    "db:doctor": "tsx src/db-doctor-cli.ts",
    "start": "node dist/server.js",
    "worker": "tsx src/worker.ts",
    "worker:dry-run": "tsx src/worker.ts --once",
    "lint": "node --max-old-space-size=4096 ../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "test": "vitest run --pool forks --maxWorkers 1",
    "seed": "tsx src/seed-cli.ts",
    "business-db:migrate:postgres": "tsx src/business-db-migrate-cli.ts",
    "backup:db": "tsx src/backup-cli.ts",
    "restore:db": "tsx src/restore-cli.ts"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/static": "^8.3.0",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.4.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "playwright-core": "^1.58.2",
    "qrcode": "^1.5.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
